# Only needed if the Flask backend isn't on http://127.0.0.1:5000 during
# `npm run dev` (used by vite.config.js's proxy), or if you're serving the
# built frontend from a different origin than the backend in production.

# Dev-time proxy target (read by vite.config.js, NOT exposed to the browser)
VITE_BACKEND_URL=http://127.0.0.1:5000

# Production: base URL the browser should call directly (bypasses the dev
# proxy). Leave unset if the frontend is served from the same origin as the
# Flask app, or behind a reverse proxy that forwards /api to Flask.
# VITE_API_BASE_URL=http://127.0.0.1:5000
